generator client {
  provider = "prisma-client-js"
}

datasource db {
  // PRODUCTION on managed PostgreSQL (Supabase/Neon/etc.).
  //   DATABASE_URL = pooled connection (used by the running app)
  //   DIRECT_URL   = direct connection (used by prisma migrate/db push)
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  phone             String?
  password          String
  role              String    @default("reporter")
  preferredLanguage String    @default("en")
  country           String?
  city              String?
  organization      String?
  isActive          Boolean   @default(true)
  isApproved        Boolean   @default(true)
  expoPushToken     String?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  reportedCases        Case[]                @relation("CaseReporter")
  assignedCases        Case[]                @relation("CaseAssignedAgent")
  fieldInvestigations  FieldInvestigation[]
  donations            Donation[]
  auditLogs            AdminAuditLog[]
  notifications        Notification[]
  sponsorships         Sponsorship[]         @relation("UserSponsorships")
  monthlyUpdates       MonthlyUpdate[]       @relation("UserMonthlyUpdates")
  projectContributions ProjectContribution[] @relation("UserProjectContributions")
  sentMessages         Message[]             @relation("MessageSender")
  messageThreadsAsA    MessageThread[]       @relation("ThreadParticipantA")
  messageThreadsAsB    MessageThread[]       @relation("ThreadParticipantB")
  vaultDocuments       VaultDocument[]
  authoredNotes        Note[]                @relation("NoteAuthor")
  assignedNotes        Note[]                @relation("NoteAssignee")
  channelMemberships   ChannelMember[]       @relation("ChannelMembers")
  chatMessages         ChatMessage[]         @relation("ChatSender")

  @@index([role])
  @@index([email])
  @@index([isActive])
  @@index([isApproved])
}

model Case {
  id              String    @id @default(cuid())
  caseRef         String?   @unique
  reporterId      String?
  reporter        User?     @relation("CaseReporter",      fields: [reporterId],      references: [id])
  assignedAgentId String?
  assignedAgent   User?     @relation("CaseAssignedAgent", fields: [assignedAgentId], references: [id])

  // Private victim data — never expose publicly
  privateVictimName   String?
  privateVictimPhone  String?
  privateAddress      String?
  privateDistrict     String?
  privateGpsLat       Float?
  privateGpsLng       Float?
  privateFamilySize   Int?
  privateVictimAge    Int?
  privateVictimGender String?
  privateGuardianName String?
  privateDescription  String?
  privateNotes        String?

  category        String   @default("other")
  caseType        String   @default("emergency")
  emergencyLevel  String   @default("medium")
  supportType     String?
  status          String   @default("pending_review")
  rejectedAt      DateTime?
  rejectionReason String?

  targetGoal      Float    @default(0)
  totalRaised     Float    @default(0)
  escrowReleased  Float    @default(0)

  // Public (sanitized) data — safe to show donors
  publicTitle      String?
  publicStory      String?
  publicCity       String?
  publicCountry    String?
  publicMediaUrls  String?   // JSON array stored as String (SQLite compat)
  aiSanitizedAt    DateTime?
  adminPublishedAt DateTime?

  teamAssignedAt           DateTime?
  investigationCompletedAt DateTime?
  sponsoredAt              DateTime?
  completedAt              DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  mediaFiles         CaseMedia[]
  fieldInvestigation FieldInvestigation?
  aiPublicData       AiPublicData?
  deliveryProof      DeliveryProof?
  donations          Donation[]
  auditLogs          AdminAuditLog[]
  notifications      Notification[]

  // ── Indexes for common query patterns ──
  @@index([status])                      // filter by status (most common)
  @@index([reporterId])                  // reporter's own cases
  @@index([assignedAgentId])             // field agent assignments
  @@index([emergencyLevel])              // sort/filter by urgency
  @@index([createdAt])                   // pagination (newest first)
  @@index([status, createdAt])           // status filter + date sort combined
}

model CaseMedia {
  id         String   @id @default(cuid())
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id])
  type       String   @default("image")
  url        String
  filename   String
  mimeType   String
  sizeBytes  Int?
  isPublic   Boolean  @default(false)
  isFlagged  Boolean  @default(false)
  flagReason String?
  uploadedBy String?
  uploadedAt DateTime @default(now())

  @@index([caseId])
  @@index([isPublic])
}

model FieldInvestigation {
  id      String @id @default(cuid())
  caseId  String @unique
  case    Case   @relation(fields: [caseId], references: [id])
  agentId String
  agent   User   @relation(fields: [agentId], references: [id])

  victimVerified        Boolean @default(false)
  situationAccurate     Boolean @default(false)
  situationNotes        String?
  gpsVerificationLat    Float?
  gpsVerificationLng    Float?
  estimatedAmountNeeded Float   @default(0)
  urgencyConfirmed      String?
  deliveryFeasible      Boolean @default(true)
  deliveryMethod        String?
  deliveryNotes         String?
  fraudRiskScore        Int     @default(0)
  fraudRiskLevel        String  @default("low")
  fraudRiskNotes        String?
  verificationStatus    String  @default("needs_review")
  officialNotes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agentId])
  @@index([verificationStatus])
  @@index([fraudRiskLevel])
}

model AiPublicData {
  id     String @id @default(cuid())
  caseId String @unique
  case   Case   @relation(fields: [caseId], references: [id])

  generatedTitle    String
  generatedStory    String
  generatedCategory String
  generatedCity     String?
  generatedUrgency  String
  safeMediaUrls     String?
  piiDetected       Boolean @default(false)
  piiRemoved        String?   // JSON array as String
  mediaFlagged      String?   // JSON array as String
  confidenceScore   Int     @default(0)
  adminEdited       Boolean @default(false)
  adminEditedTitle  String?
  adminEditedStory  String?
  model             String  @default("claude-sonnet-4-6")
  tokensUsed        Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Donation {
  id             String    @id @default(cuid())
  donorId        String
  donor          User      @relation(fields: [donorId], references: [id])
  caseId         String
  case           Case      @relation(fields: [caseId], references: [id])
  amount         Float
  currency       String    @default("USD")
  method         String    @default("bank_transfer")
  status         String    @default("pending")
  transactionRef String?
  confirmedAt    DateTime?
  isAnonymous    Boolean   @default(false)
  donorMessage   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([donorId])
  @@index([caseId])
  @@index([status])
  @@index([donorId, status])   // donor's confirmed donations
}

model DeliveryProof {
  id              String    @id @default(cuid())
  caseId          String    @unique
  case            Case      @relation(fields: [caseId], references: [id])
  deliveredBy     String    // field agent user ID
  deliveryDate    DateTime
  deliveryMethod  String
  amountDelivered Float
  recipientName   String?
  deliveryNotes   String?
  photoUrls       String?   // JSON array of Supabase Storage URLs
  adminConfirmed  Boolean   @default(false)
  adminConfirmedAt DateTime?
  adminNotes      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([adminConfirmed])
}

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])
  action    String
  notes     String?
  metadata  String?
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([adminId])
  @@index([caseId])
  @@index([action])
  @@index([timestamp])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  caseId    String?
  case      Case?     @relation(fields: [caseId], references: [id])
  type      String
  title     String
  message   String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([userId, isRead])   // unread count query
  @@index([createdAt])
}

model IdempotencyKey {
  key       String   @id
  createdAt DateTime @default(now())
}

// ─── Humanitarian Programs Engine ────────────────────────────────────────────

model Program {
  id          String  @id @default(cuid())
  name        String
  type        String
  description String
  icon        String  @default("🌱")
  color       String  @default("#004B96")
  isActive    Boolean @default(true)

  totalBeneficiaries Int   @default(0)
  activeSponsorships Int   @default(0)
  monthlyBudget      Float @default(0)
  totalRaised        Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  beneficiaries Beneficiary[]

  @@index([type])
  @@index([isActive])
}

model Beneficiary {
  id       String @id @default(cuid())
  publicId String @unique

  programId String
  program   Program @relation(fields: [programId], references: [id])

  privateFullName      String?
  privateGuardianName  String?
  privateGuardianPhone String?
  privateSchoolName    String?
  privateAddress       String?
  privateMedicalNotes  String?
  privateNotes         String?

  publicAge       Int?
  publicGender    String?
  publicRegion    String?
  publicCity      String?
  publicCountry   String  @default("Somalia")
  publicNeedsDesc String?
  publicStory     String?
  publicPhotoUrl  String?

  programType String
  monthlyNeed Float  @default(0)

  status      String    @default("pending_verification")
  verifiedAt  DateTime?
  verifiedById String?
  enrolledBy  String?
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sponsorships   Sponsorship[]
  monthlyUpdates MonthlyUpdate[]

  @@index([status])
  @@index([programId])
  @@index([programType])
}

model Sponsorship {
  id            String      @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])
  sponsorId     String
  sponsor       User        @relation("UserSponsorships", fields: [sponsorId], references: [id])

  type          String @default("full")
  monthlyAmount Float
  currency      String @default("USD")
  status        String @default("active")
  paymentMethod String @default("bank_transfer")

  startDate       DateTime  @default(now())
  endDate         DateTime?
  nextPaymentDate DateTime?

  totalPaid       Float @default(0)
  monthsCompleted Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments SponsorshipPayment[]

  @@index([beneficiaryId])
  @@index([sponsorId])
  @@index([status])
}

model SponsorshipPayment {
  id            String      @id @default(cuid())
  sponsorshipId String
  sponsorship   Sponsorship @relation(fields: [sponsorshipId], references: [id])

  amount   Float
  currency String @default("USD")
  month    Int
  year     Int
  status   String @default("pending")

  paidAt      DateTime?
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([sponsorshipId])
}

model MonthlyUpdate {
  id            String      @id @default(cuid())
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])
  submittedById String
  submittedBy   User        @relation("UserMonthlyUpdates", fields: [submittedById], references: [id])

  month Int
  year  Int

  schoolAttendance Int?
  healthStatus     String?
  progressNotes    String
  needsAssessment  String?

  deliveriesMade String?  // JSON array as String
  photoUrls      String?  // JSON array as String

  isPublished Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([beneficiaryId, month, year])
  @@index([beneficiaryId])
  @@index([isPublished])
}

// ─── Community Projects ───────────────────────────────────────────────────────

model CommunityProject {
  id       String @id @default(cuid())
  publicId String @unique

  title       String
  description String
  category    String
  location    String
  region      String
  country     String @default("Somalia")

  populationSize Int?
  problemDesc    String
  solutionDesc   String

  fundingGoal Float
  totalRaised Float @default(0)

  status           String  @default("seeking_funding")
  phases           String? // JSON array as String
  photoUrls        String? // JSON array as String
  completionReport String?

  createdById String?
  verifiedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contributions ProjectContribution[]

  @@index([status])
  @@index([category])
}

model ProjectContribution {
  id        String           @id @default(cuid())
  projectId String
  project   CommunityProject @relation(fields: [projectId], references: [id])
  donorId   String
  donor     User             @relation("UserProjectContributions", fields: [donorId], references: [id])

  amount   Float
  currency String @default("USD")
  type     String @default("partial")
  status   String @default("pending")

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([donorId])
}

// ─── Impact Partners ─────────────────────────────────────────────────────────

model Partner {
  id   String @id @default(cuid())
  name String
  slug String @unique

  avatar  String @default("🤝")
  logoUrl String?

  type        String  @default("individual")
  tier        String  @default("community")
  isVerified  Boolean @default(false)
  isAnonymous Boolean @default(false)
  isActive    Boolean @default(true)

  country     String?
  countryFlag String?
  city        String?
  region      String?

  description String?
  website     String?
  focus       String? // JSON array as String
  color       String  @default("#004B96")

  casesSupported   Int   @default(0)
  totalDonated     Float @default(0)
  familiesImpacted Int   @default(0)

  impactStory  String?
  impactBefore String?
  impactAfter  String?
  caseRef      String?

  featuredOrder Int?
  addedByAdmin  String?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tier])
  @@index([isVerified, isActive])
  @@index([type])
  @@index([featuredOrder])
}

// ─── OTP / Password Reset ────────────────────────────────────────────────────

model OtpRecord {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ─── Messaging ────────────────────────────────────────────────────────────────

model MessageThread {
  id           String @id @default(cuid())
  participantA String
  participantB String
  userA        User   @relation("ThreadParticipantA", fields: [participantA], references: [id])
  userB        User   @relation("ThreadParticipantB", fields: [participantB], references: [id])
  caseId       String?
  lastMessage  String   @default("")
  lastAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  messages Message[]

  @@unique([participantA, participantB])
  @@index([participantA])
  @@index([participantB])
}

model Message {
  id       String        @id @default(cuid())
  threadId String
  thread   MessageThread @relation(fields: [threadId], references: [id])
  senderId String
  sender   User          @relation("MessageSender", fields: [senderId], references: [id])
  text     String
  isRead   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([threadId])
  @@index([senderId])
}

// ─── Document Vault ───────────────────────────────────────────────────────────

model VaultDocument {
  id        String @id @default(cuid())
  ownerId   String
  owner     User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title     String
  filename  String
  url       String
  type      String @default("other")
  mimeType  String?
  sizeBytes Int?
  caseRef   String?
  createdAt DateTime @default(now())

  @@index([ownerId])
  @@index([ownerId, type])
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Postgres-backed fixed-window rate limiter — counts requests per (bucket:ip:window)
// so brute-force limits hold across serverless instances (in-memory limits don't).
model RateCounter {
  key       String   @id
  count     Int      @default(0)
  expiresAt DateTime

  @@index([expiresAt])
}

// Server-side token revocation (logout / password change) — persisted so it
// works across serverless function instances. Keyed by sha256(token).
model RevokedToken {
  tokenHash String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

// ── Communication Center ─────────────────────────────────────────────────────
// A conversation: open department/announcement channel, private group, or DM.
model Channel {
  id          String   @id @default(cuid())
  name        String
  slug        String?  @unique   // stable key for seeded department channels
  type        String   @default("group") // group | department | dm | announcement | case | project | program | emergency
  description String   @default("")
  isOpen      Boolean  @default(false)   // open = visible to all staff (no explicit membership needed)
  postPolicy  String   @default("members") // members | admins (announcements = admins)
  createdBy   String?
  createdAt   DateTime @default(now())
  lastMessage String   @default("")
  lastAt      DateTime @default(now())

  members  ChannelMember[]
  messages ChatMessage[]

  @@index([type])
  @@index([lastAt])
}

model ChannelMember {
  id         String   @id @default(cuid())
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("ChannelMembers", fields: [userId], references: [id])
  role       String   @default("member") // member | owner
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([channelId, userId])
  @@index([userId])
  @@index([channelId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  channelId   String
  channel     Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User     @relation("ChatSender", fields: [senderId], references: [id])
  text        String   @default("")
  attachments String   @default("[]") // JSON array of { url, name, type }
  replyToId   String?
  createdAt   DateTime @default(now())

  @@index([channelId, createdAt])
}

// Admin/Super-Admin notebook: shared notes & assignable tasks.
model Note {
  id         String    @id @default(cuid())
  title      String
  body       String    @default("")
  status     String    @default("todo")    // todo | doing | done
  priority   String    @default("normal")  // low | normal | high
  category   String    @default("General") // admin-managed note category
  authorId   String
  author     User      @relation("NoteAuthor",   fields: [authorId],   references: [id])
  assigneeId String?
  assignee   User?     @relation("NoteAssignee", fields: [assigneeId], references: [id])
  dueDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([authorId])
  @@index([assigneeId])
  @@index([status])
}
