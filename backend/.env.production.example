# ─── Kafaale API — Production Environment Variables ─────────────────────────
# Copy this to Railway's "Variables" tab (or your host's env config panel)
# DO NOT commit real values to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── PostgreSQL (Supabase project "kafaale-qaad", ref cassihxdqqpkrzpsaesl) ────
# Get exact host + password from: Supabase → kafaale-qaad → Connect → ORMs → Prisma
# Prisma needs BOTH: pooled (6543) for the app, direct/session (5432) for migrate.
DATABASE_URL=postgresql://postgres.cassihxdqqpkrzpsaesl:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.cassihxdqqpkrzpsaesl:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET

# ── Anthropic AI (Claude) ─────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY

# ── URLs ──────────────────────────────────────────────────────────────────────
# BASE_URL = your Railway backend URL (set after first deploy)
BASE_URL=https://kafaale-api.up.railway.app
# FRONTEND_URL = your Vercel frontend URL
FRONTEND_URL=https://kafaale.vercel.app

# ── File Storage (Supabase Storage) ──────────────────────────────────────────
# Get from: Supabase → Settings → API
SUPABASE_URL=https://cassihxdqqpkrzpsaesl.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_WITH_service_role_KEY
SUPABASE_STORAGE_BUCKET=kafaale-media
