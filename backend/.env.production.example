# ─── Kafaale API — Production Environment Variables ─────────────────────────
# Copy this to Railway's "Variables" tab (or your host's env config panel)
# DO NOT commit real values to git

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── PostgreSQL (Supabase project "kafaale-pro", ref sdfjckovzhtospxdvuaf) ─────
# PRODUCTION DB since 2026-07-20. App connects as least-privilege role "kafaale_app"
# (NOT the master postgres role). Password: see the commented "kafaale-pro" block
# in backend/.env on the dev machine, or reset via SQL as postgres.
# Prisma needs BOTH: pooled (6543) for the app, direct/session (5432) for migrate.
DATABASE_URL=postgresql://kafaale_app.sdfjckovzhtospxdvuaf:[KAFAALE_APP-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://kafaale_app.sdfjckovzhtospxdvuaf:[KAFAALE_APP-PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET

# ── Anthropic AI (Claude) ─────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_REAL_KEY

# ── URLs ──────────────────────────────────────────────────────────────────────
# BASE_URL = your Railway backend URL (set after first deploy)
BASE_URL=https://kafaale-api.up.railway.app
# FRONTEND_URL = your Vercel frontend URL
FRONTEND_URL=https://kafaale.vercel.app

# ── File Storage (Supabase Storage, project "kafaale-pro") ───────────────────
# Get from: Supabase → kafaale-pro → Settings → API
SUPABASE_URL=https://sdfjckovzhtospxdvuaf.supabase.co
SUPABASE_SERVICE_KEY=REPLACE_WITH_service_role_KEY
SUPABASE_STORAGE_BUCKET=kafaale-media
