# ────────────────────────────────────────────────────────────────
# Kafaale Qaad API — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────
#
# LOCAL DEV (recommended): run `docker compose up -d` from the repo root, then use:
DATABASE_URL="postgresql://kafaale:kafaale@localhost:5432/kafaale"
DIRECT_URL="postgresql://kafaale:kafaale@localhost:5432/kafaale"
#
# PRODUCTION (Supabase): Dashboard → Settings → Database → Connection String
#   DATABASE_URL = "Transaction" pooler URL (port 6543, ?pgbouncer=true) — the running app
#   DIRECT_URL   = "Session" / direct URL  (port 5432)                    — prisma migrate/db push
# DATABASE_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[ref]:[pw]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── Authentication ───────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# ── AI Sanitization (Anthropic Claude) ──────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── File Uploads ─────────────────────────────────────────────────
BASE_URL="http://localhost:4000"
# For production:
# BASE_URL="https://your-api.railway.app"

# ── Frontend URL (CORS) ──────────────────────────────────────────
FRONTEND_URL="http://localhost:5173"
# For production:
# FRONTEND_URL="https://your-frontend.vercel.app"

# ── Supabase Storage (REQUIRED in production for media uploads) ───
# Without these the API falls back to local disk, which is WIPED on every
# redeploy on Render/Railway. Set both in production.
# SUPABASE_URL="https://[project-ref].supabase.co"
# SUPABASE_SERVICE_KEY="eyJ..."   # service_role key (NOT the anon key)
