{
  "buildCommand": "npm run build && cd backend && npm install && npx prisma generate && npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
