# ────────────────────────────────────────────────────────────────
# Kafaale Qaad — Frontend (Vite) Environment Variables
# Copy to .env.local for local dev, and set in your host (Vercel) for prod.
# ────────────────────────────────────────────────────────────────

# Base URL of the backend API, including the /api suffix.
#   Local dev:  http://localhost:4000/api   (or leave unset — this is the dev default)
#   Production: https://api.yourdomain.com/api   (your deployed backend)
# If unset in production, the app falls back to same-origin "/api".
VITE_API_URL=
